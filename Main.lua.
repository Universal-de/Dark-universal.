local fov_circ = Drawing.new("Circle")
fov_circ.Thickness = 1; fov_circ.NumSides = 100; fov_circ.Radius = SETTINGS.FOV; fov_circ.Visible = false; fov_circ.Color = ACCENT

local function GetClosest()
    local t, dist = nil, SETTINGS.FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then dist = mag; t = p end
            end
        end
    end
    return t
end

Connections.Loop = RunService.RenderStepped:Connect(function()
    -- FOV Circle
    fov_circ.Visible = SETTINGS.FOVOverlay
    fov_circ.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    -- Streamer Mode
    if SETTINGS.StreamerMode then
        LocalPlayer.DisplayName = "Anonymous_Hacker"
    end

    -- Smooth Aim
    if SETTINGS.Aimbot then
        local t = GetClosest()
        if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character.Head.Position), SETTINGS.Smoothness) end
    end
    
    -- Speed
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = SETTINGS.Speed and 75 or 16
    end

    -- ESP
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("Highlight")
            if SETTINGS.Esp then
                if not h then h = Instance.new("Highlight", p.Character) end
                h.Enabled = true; h.FillColor = ACCENT
            elseif h then h.Enabled = false end
        end
    end
end)

-- Metamethods (Silent Aim & HitSounds)
local old; old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "Raycast" and SETTINGS.SilentAim then
        local t = GetClosest()
        if t then args[2] = (t.Character.Head.Position - args[1]).Unit * 1000 end
    end
    
    if method == "FireServer" and SETTINGS.HitSounds and self.Name == "HitPart" then
        local s = Instance.new("Sound", SoundService)
        s.SoundId = "rbxassetid://160432334"; s:Play() -- Classic Ding
    end
    
    return old(self, unpack(args))
end)

