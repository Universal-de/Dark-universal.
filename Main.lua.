local function AddTab(name, page, isPrivate)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size = UDim2.new(1, -10, 0, 35); btn.Text = name; btn.Font = "GothamBold"; btn.TextColor3 = Color3.fromRGB(150,150,150); btn.BackgroundTransparency = 1
    if isPrivate then btn.Visible = false end

    btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages:GetChildren()) do p.Visible = false end
        page.Visible = true
        for _, b in pairs(Sidebar:GetChildren()) do if b:IsA("TextButton") then b.TextColor3 = Color3.fromRGB(150,150,150) end end
        btn.TextColor3 = isPrivate and PRIVATE_ACCENT or ACCENT
    end)
    return btn
end

